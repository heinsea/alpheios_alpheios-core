{
  "name": "alpheios-components-v3",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Scholarly Glass v3 UI for Alpheios — Vue 3 + Vite. Greenfield rewrite parallel to legacy `alpheios-components` (Vue 2). See doc/ui/REFACTOR-V3-PLAN.md in the webextension repo.",
  "type": "module",
  "main": "./dist/components-v3.umd.cjs",
  "module": "./dist/components-v3.js",
  "types": "./src/index.js",
  "style": "./dist/style.css",
  "exports": {
    ".": {
      "import": "./dist/components-v3.js",
      "require": "./dist/components-v3.umd.cjs"
    },
    "./style.css": "./dist/style.css",
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  }
}
