          { "id": "hideLogin",       "kind": "toggle",    "label": "Hide login prompt", "help": "Suppress the \"log in to sync\" inline card.", "value": false },
          { "id": "reduceMotion",    "kind": "segInline", "label": "Reduce motion",     "help": "Auto-detected from <code>prefers-reduced-motion</code>.", "value": "auto",
            "options": [{ "value": "auto", "label": "Auto" }, { "value": "off", "label": "Off" }] }
        ]
      }
    ]
  },
  "features": {
    "groups": [
      {
        "title": "Lookup behavior",
        "rows": [
          { "id": "autoLookup",       "kind": "toggle", "label": "Auto-lookup on selection", "help": "Show popup automatically when text is selected.", "value": true },
          { "id": "doubleClick",      "kind": "toggle", "label": "Lookup on double-click",   "help": "Single word lookup without dragging.",            "value": true },
          { "id": "collapseShortDef", "kind": "toggle", "label": "Collapse short definitions","help": "Show only first definition in popup; expand on click.", "value": false }
