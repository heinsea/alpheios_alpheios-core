          { "id": "popupMaxWidth",   "kind": "slider",    "label": "Popup max width", "help": "Cap on the floating popup. Range 240–600.", "min": 240, "max": 600, "value": 360, "unit": "" },
          { "id": "showFab",         "kind": "toggle",    "label": "Show toolbar FAB","help": "Floating button bottom-right when no selection.", "value": true }
